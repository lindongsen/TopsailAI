# set environ
TOPSAILAI_AGENT_NAME="AI-Alice"

#OPENAI_MODEL="Kimi-K2.5"
OPENAI_MODEL="MiniMax-M2.5"
OPENAI_API_KEY="sk-1234"
OPENAI_API_BASE="http://172.18.0.4:7000"

TOPSAILAI_ENABLED_TOOLS="skill_tool;file_readonly_tool"
TOPSAILAI_DISABLED_TOOLS=""

TOPSAILAI_DISABLED_SKILLS="ai-community"
TOPSAILAI_LOAD_OVERVIEW_INTO_PROMPT_SKILLS="/topsailai/skill"

TOPSAILAI_CMD_ENV_KEYS="MESSENGER_RECEIVER;MESSENGER_SENDER;MESSENGER_MODE"

DEBUG=0
TOPSAILAI_INTERACTIVE_MODE=0
TOPSAILAI_NEED_SYMBOL_FOR_ANSWER=1
