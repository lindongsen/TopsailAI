# =============================================================================
# OpenAI Configuration
# =============================================================================

# OpenAI Model Configuration
# Default model used for LLM interactions
OPENAI_MODEL="DeepSeek-V3.1-Terminus"

# OpenAI API Key
# Required for accessing OpenAI-compatible API endpoints
OPENAI_API_KEY=""

# OpenAI API Base URL
# Base URL for OpenAI-compatible API services
OPENAI_API_BASE="https://openapi.coreshub.cn/v1"


# =============================================================================
# Multi-Model Configuration
# =============================================================================

# Multiple Model Configuration
# Format: Multiple model configurations separated by semicolons (';')
# Each model: key-value pairs separated by commas (',')
# Example: api_key=aaa,api_base=bbb;api_key=ccc,api_base=ddd
# Purpose: Allows using multiple LLM providers with automatic failover
TOPSAILAI_MODEL_SETTINGS=""


# =============================================================================
# Application Settings
# =============================================================================

# Debug Mode
# 0 = Production mode (disabled)
# 1 = Debug mode (enabled) - enables verbose logging and debugging features
DEBUG=1

DEBUG_PRINT_TRUNCATE_LENGTH=3000

# Interactive Mode, 1 for enabled, 0 for disabled
TOPSAILAI_INTERACTIVE_MODE=1

# Print tool prompt content
TOPSAILAI_PRINT_TOOL_PROMPT=0

# Input Messages
TOPSAILAI_CHAT_MULTI_LINE=0

# file or content pass to message of agent
TOPSAILAI_TASK=""

# Agent Type, default is react
TOPSAILAI_AGENT_TYPE=""

# default agent name
TOPSAILAI_AGENT_NAME="TopsailAI"

# Human name
TOPSAILAI_HUMAN_NAME = "Topsail"

# =============================================================================
# LLM Parameters
# =============================================================================

# Maximum Tokens
# Maximum number of tokens to generate in each LLM response
MAX_TOKENS=8000

# Temperature
# Controls randomness: 0.0 = deterministic, 1.0 = creative
TEMPERATURE=0.3

# Top P (Commented out - available for advanced configuration)
# Controls diversity via nucleus sampling
TOP_P=0.97

# Frequency Penalty (Commented out - available for advanced configuration)
# Penalizes repeated tokens: 0.0 = no penalty, 1.0 = maximum penalty
FREQUENCY_PENALTY=0.0

# =============================================================================
# LLM Interactive
# =============================================================================

# Use streaming response
LLM_RESPONSE_STREAM=1

# Interactive mode in StepCall, 0 for auto
TOPSAILAI_CHAT_INTERACTIVE_MODE=0

# =============================================================================
# System Prompt
# =============================================================================

# one file or content. Extend system prompts.
# SYSTEM_PROMPT=""

# multiple files, split by ','
# SYSTEM_PROMPT_EXTRA_FILES=""

# one file or content. Describe the current environmental information.
# ENV_PROMPT=""

# =============================================================================
# System Prompt Control
# =============================================================================

# Pure system prompt will only have the working mode. 1 for enabled.
PURE_SYSTEM_PROMPT=0

# =============================================================================
# Context Management
# =============================================================================

# Session Management
# SESSION_ID=
# When set, enables session-based chat history persistence
# Example usage:
#   SESSION_ID=001 llm_chat "your message here"
#   ai_list_sessions - lists all available sessions
#   ai_retrieve_messages 001 - retrieves messages for session 001

# Lock session, agent_shell: start -> lock session -> refresh session -> agent_run
TOPSAILAI_ENABLE_SESSION_LOCK=0

# Chat History Managers
# Format: Manager classes separated by semicolons (';')
# Each manager: class_name parameters separated by spaces (' ')
# If not set, context management is disabled
# Current implementation supports SQLAlchemy-based storage
CONTEXT_HISTORY_MANAGERS="sql.ChatHistorySQLAlchemy conn=sqlite:///memory.db;"

# Message Slimming Threshold to optimize context window usage and prevent token overflow
# Length longer than this threshold will be automatically slimmed
CONTEXT_MESSAGES_SLIM_THRESHOLD_LENGTH=43
# Tokens longer than this threshold will be automatically slimmed
CONTEXT_MESSAGES_SLIM_THRESHOLD_TOKENS=10000

# When the number of messages reaches a threshold, they will be summarized to limit the message length
# TOPSAILAI_CONTEXT_MESSAGES_QUANTITY_THRESHOLD=97
# TOPSAILAI_CONTEXT_MESSAGES_HEAD_OFFSET_TO_KEEP=0

# Keep session messages after summarizing, 1 is enabled(default), 0 is disabled
TOPSAILAI_CTX_SUMMARY_KEEP_SESSION_MESSAGES=1

# ONLY RUNTIME: default is 0 to disable;
# if set it to 1, but not set TOPSAILAI_SYMBOL_STARTSWITH_ANSWER, default symbol is agent name
# Exmaple: `From 'AI.Dawson': {answer}`
TOPSAILAI_NEED_SYMBOL_FOR_ANSWER=0

# ONLY RUNTIME: a symbol string for answer
# TOPSAILAI_SYMBOL_STARTSWITH_ANSWER=""

# ONLY RUNTIME: a file path to save answer
# TOPSAILAI_SAVE_RESULT_TO_FILE=""

# Prompt for summary, file or content
TOPSAILAI_SUMMARY_PROMPT=""

# Extra Prompt for summary
# Format "key1=value1,value2;key2=value2", key is agent_type, value are files
TOPSAILAI_SUMMARY_PROMPT_EXTRA_MAP="react_community=context/summary/memory.md;"

# Summarize messages of agent2llm, save summary content to session of user2agent
# 1 is enabled, 0 is disabled
TOPSAILAI_HOOK_FINAL_SUMMARIZE_INTO_SESSION="0"

# =============================================================================
# Feature Flags
# =============================================================================

# Dump Messages Flag
# When set to 1, chat history messages are automatically dumped to a file
# after each execution for debugging and analysis purposes
TOPSAILAI_FLAG_DUMP_MESSAGES=0


# =============================================================================
# Tool Configuration
# =============================================================================

# Give 'tools' to chat, 0 for tool_prompt only.
TOPSAILAI_USE_TOOL_CALLS=0

# Disabled Tools
# Internal tools to disable (tools starting with these keywords)
# Format: Tool names separated by semicolons (';')
# Example: "agent_tool;story_tool" - disables all tools starting with these prefixes
TOPSAILAI_DISABLED_TOOLS=""

# Enabled Tools
# Internal tools to enable (tools starting with these keywords)
# Format: Tool names separated by semicolons (';')
# Takes precedence over DISABLED_TOOLS - only tools matching these prefixes will be available
TOPSAILAI_ENABLED_TOOLS=""

# Extra Tools
# Additional external tools to include in the agent's toolset
# Format: File paths separated by semicolons (';')
# Each tool should be defined in a separate Markdown (.md) file
TOPSAILAI_EXTRA_TOOLS=""

# Plugin Tools
# External plugin tools to dynamically load
# Format: Plugin directory paths separated by semicolons (';')
# Each plugin is loaded from a separate directory and integrated via the 'TOOLS' variable
TOPSAILAI_PLUGIN_TOOLS=""

# default char is '-', example file_tool-read_file
TOPSAILAI_TOOL_CONN_CHAR="-"

# White list for file extensions do not truncate, split by ';'
TOPSAILAI_FILE_WHITE_LIST_NO_TRUNCATE_EXT=""


# =============================================================================
# Skill Configuration
# =============================================================================

# Plugin Skills
# Format: directory paths separated by semicolons (';')
TOPSAILAI_PLUGIN_SKILLS=""     # support to search folder with max depth TOPSAILAI_SEARCH_SKILLS_MAX_DEPTH(default 3)
TOPSAILAI_SEARCH_SKILLS_MAX_DEPTH=3
TOPSAILAI_DISABLED_SKILLS=""
TOPSAILAI_LOAD_OVERVIEW_INTO_PROMPT_SKILLS=""

# Lock session before calling these skills
TOPSAILAI_SESSION_LOCK_ON_SKILLS=""

# Refresh session after calling these skills
TOPSAILAI_SESSION_REFRESH_ON_SKILLS=""

# Format 'skill_folder=timeout' separated by semicolons (';')
TOPSAILAI_CALL_SKILL_TIMEOUT_MAP="ai-community=86400"

# Skill Hooks, module dir paths separated by semicolons (';')
TOPSAILAI_HOOK_MODULE_SKILLS=""

# =============================================================================
# Sandbox Configuration
# =============================================================================

# Sandbox Environment Settings
# Format: Multiple sandbox configurations separated by semicolons (';')
# Each sandbox: key-value pairs separated by commas (',')
# Example: tag=ai,protocol=ssh,node=hostname;tag=ai,protocol=docker,node=host,name=container
# Supported protocols: ssh, docker
# Purpose: Enables command execution in isolated environments
TOPSAILAI_SANDBOX_SETTINGS=""

# Envion keys separated by semicolons (';')
TOPSAILAI_CMD_ENV_KEYS=""

# =============================================================================
# CLI Configuration
# =============================================================================

# Format: Tool names separated by semicolons (';')
# TOPSAILAI_CLI_AGENT_CHAT_DISABLED_TOOLS="agent_tool"

# =============================================================================
# HOOK Configuration
# =============================================================================

# Format: Module paths separated by semicolons (';')
# hook_func(content:str) -> list[dict]|str
TOPSAILAI_HOOK_AFTER_LLM_CHAT=""

# Format: Module paths separated by semicolons (';')
# hook_func(content:list[dict]) -> list[dict]
TOPSAILAI_HOOK_BEFORE_LLM_CHAT=""

# =============================================================================
# Team Configuration
# =============================================================================

# file or content
TOPSAILAI_TEAM_PROMPT=""

# folder path to team member
TOPSAILAI_TEAM_PATH=""

# 1 to save, 0 is not save. team_agent can store the first message (task) and the last message (final_answer)
TOPSAILAI_TEAM_AGENT_SESSION_NEED_SAVE_MESSAGE=""

# one number for offset (msgs[:offset] + msgs[-offset:])
TOPSAILAI_TEAM_SESSION_HEAD_AND_TAIL_OFFSET=""

# env keys pass to team_agent
TOPSAILAI_TEAM_ENV_KEYS=""

# only agent
TOPSAILAI_TEAM_MANAGER_ONLY_AGENT=1 # 0 for disabled (default), 1 for enabled

# manager name
TOPSAILAI_TEAM_MANAGER_NAME="TopsailAI"

# memeber name, DONOT CONFIG it, only setting it for runtime.
# TOPSAILAI_TEAM_MEMBER_NAME="km-k25"

# =============================================================================
# Instruction Configuration
# =============================================================================

# Plugin Instructions, expand it from external folders
# Format: directory paths separated by semicolons (';')
# Reference: topsailai.workspace.plugin_instruction
TOPSAILAI_PLUGIN_INSTRUCTIONS=""

# =============================================================================
# Story Configuration
# =============================================================================

# Story prompt will be used when generating stories based on historical messages.
TOPSAILAI_STORY_PROMPT=""

# Use the LLM to generate story, e.g. DeepSeek-V3.2
TOPSAILAI_STORY_MODEL=""

# Save stories to the workspace
TOPSAILAI_STORY_WORKSPACE=""

# =============================================================================
# Memory Configuration
# =============================================================================

# Save memories to the workspace
TOPSAILAI_MEMORY_WORKSPACE=""

# =============================================================================
# Task Configuration
# =============================================================================

# DONOT SET IT, only for runtime.
# TOPSAILAI_TASK_ID=""
