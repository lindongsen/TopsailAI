# topsailai_data example environment configuration
# Author: DawsonLin

# Root directory for local storage.
# When unset, the CLI defaults to ${HOME}/.topsailai/data/.
TOPSAILAI_DATA_ROOT=./data

# Adapter selection
TOPSAILAI_DATA_METADATA_ADAPTER=local
TOPSAILAI_DATA_ACTUAL_DATA_ADAPTER=local

# Optional behavior
TOPSAILAI_DATA_INCLUDE_DELETED=false
TOPSAILAI_DATA_READ_LOCK=0
TOPSAILAI_DATA_CEASED_RETENTION_DAYS=30
TOPSAILAI_DATA_LOG_LEVEL=INFO

# Example adapter-specific setting (not used by the local adapter)
# TOPSAILAI_DATA_ADAPTER_S3_BUCKET=my-bucket
