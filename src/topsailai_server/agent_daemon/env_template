# Agent Daemon Environment Variables Template
# Copy this file to .env and customize for your deployment.

# =============================================================================
# Server Configuration
# =============================================================================

# Host IP address to listen on
# Default: 0.0.0.0
# TOPSAILAI_AGENT_DAEMON_HOST=0.0.0.0

# Port number to listen on
# Default: 7373
# TOPSAILAI_AGENT_DAEMON_PORT=7373

# Database URL for SQLAlchemy
# Default: sqlite:///topsailai_agent_daemon.db
# TOPSAILAI_AGENT_DAEMON_DB_URL=sqlite:///topsailai_agent_daemon.db

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
# TOPSAILAI_AGENT_DAEMON_LOG_LEVEL=INFO

# =============================================================================
# Worker Scripts
# =============================================================================

# Script to process messages. When it finishes, it records the result to storage.
# Required. Must be an executable script.
# TOPSAILAI_AGENT_DAEMON_PROCESSOR=/path/to/processor.py

# Script to summarize messages. The daemon does not care about the result.
# Required. Must be an executable script.
# TOPSAILAI_AGENT_DAEMON_SUMMARIZER=/path/to/summarizer.py

# Script to check session state (idle/processing).
# Required. Must be an executable script.
# TOPSAILAI_AGENT_DAEMON_SESSION_STATE_CHECKER=/path/to/session_state_checker.py

# =============================================================================
# API Key Authentication
# =============================================================================

# Enable or disable API key authentication.
# When enabled, all endpoints require authentication via one of the following:
#   - X-API-Key header: X-API-Key: <api_key_value>
#   - Authorization header: Authorization: Bearer <api_key_value>
# When disabled, no authentication is required.
# Default: false
# TOPSAILAI_AGENT_DAEMON_API_KEY_ENABLED=false

# Optional: Pre-configured default admin API key.
# If not set, a random admin key is generated on first startup.
# This key has full admin privileges (all sessions, API key management).
# Only used when API_KEY_ENABLED is true.
# TOPSAILAI_AGENT_DAEMON_DEFAULT_ADMIN_KEY=

# =============================================================================
# Client Configuration
# =============================================================================

# Base URL for the agent daemon API (used by clients)
# Default: http://127.0.0.1:7373
# TOPSAILAI_AGENT_DAEMON_BASE_URL=http://127.0.0.1:7373

# API key for client authentication (used by topsailai_agent_client, terminal, etc.)
# Required when API_KEY_ENABLED is true.
# TOPSAILAI_AGENT_DAEMON_API_KEY=

# Authentication header style for clients.
# Supported values: "x-api-key" (default) or "bearer".
# When set to "x-api-key", the client sends the API key via the X-API-Key header.
# When set to "bearer", the client sends the API key via the Authorization header
# in the format "Bearer <api_key_value>".
# Default: x-api-key
# TOPSAILAI_AGENT_DAEMON_AUTH_STYLE=x-api-key

# =============================================================================
# Advanced Configuration
# =============================================================================

# Comma-separated list of roles to include in unprocessed messages.
# Default: user
# TOPSAILAI_AGENT_DAEMON_UNPROCESSED_MSG_INCLUDED_ROLES=user
